# ╔══════════════════════════════════════════════════════════════════╗
# ║              PARMANA 2.0 — ENVIRONMENT VARIABLES                ║
# ║   Copy this file to .env and fill in your keys.                 ║
# ║   Never commit .env to version control.                         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                  # development | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
DEFAULT_PROVIDER=openai              # fallback provider if none specified

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=                       # optional
OPENAI_BASE_URL=                     # override for proxies / Azure

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_BASE_URL=                  # override if using Claude CLI proxy

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Mistral ───────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=...

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# ── Alibaba Model Studio (DashScope / Qwen) ───────────────────────────────────
DASHSCOPE_API_KEY=sk-...
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── BytePlus (International) ──────────────────────────────────────────────────
BYTEPLUS_API_KEY=...
BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# ── xAI (Grok) ────────────────────────────────────────────────────────────────
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1

# ── Fireworks AI ──────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=fw_...
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ── Cloudflare AI Gateway ─────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_GATEWAY_ID=...
CLOUDFLARE_API_KEY=...
# Constructed URL: https://gateway.ai.cloudflare.com/v1/{ACCOUNT_ID}/{GATEWAY_ID}

# ── fal (image/video) ─────────────────────────────────────────────────────────
FAL_KEY=...

# ── Runway ────────────────────────────────────────────────────────────────────
RUNWAY_API_KEY=...

# ── GLM / Zhipu AI ────────────────────────────────────────────────────────────
ZHIPUAI_API_KEY=...

# ── MiniMax ───────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=...
MINIMAX_GROUP_ID=...
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ── Moonshot AI (Kimi) ────────────────────────────────────────────────────────
MOONSHOT_API_KEY=...
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ── StepFun ───────────────────────────────────────────────────────────────────
STEPFUN_API_KEY=...
STEPFUN_BASE_URL=https://api.stepfun.com/v1

# ── Qianfan (Baidu) ───────────────────────────────────────────────────────────
QIANFAN_ACCESS_KEY=...
QIANFAN_SECRET_KEY=...

# ── Chutes ────────────────────────────────────────────────────────────────────
CHUTES_API_KEY=...
CHUTES_BASE_URL=https://llm.chutes.ai/v1

# ── ComfyUI (local) ───────────────────────────────────────────────────────────
COMFYUI_BASE_URL=http://localhost:8188

# ── Vercel AI Gateway ─────────────────────────────────────────────────────────
VERCEL_AI_GATEWAY_URL=...
VERCEL_AI_GATEWAY_TOKEN=...

# ── Venice AI ─────────────────────────────────────────────────────────────────
VENICE_API_KEY=...
VENICE_BASE_URL=https://api.venice.ai/api/v1

# ── Z.AI ──────────────────────────────────────────────────────────────────────
ZAI_API_KEY=...
ZAI_BASE_URL=https://api.z.ai/api/v1

# ── OpenCode (Zen + Go) ───────────────────────────────────────────────────────
OPENCODE_API_KEY=...
OPENCODE_BASE_URL=https://api.opencode.ai/v1

# ── Channels ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
WHATSAPP_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_VERIFY_TOKEN=...            # webhook verification

# ── Memory ────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2    # local sentence-transformers model

# ── Vision ────────────────────────────────────────────────────────────────────
TESSERACT_CMD=                       # path to tesseract binary if not in PATH
